{
  "info": {
    "name": "Smart Expense Tracker Level 3 - Smart Wallet",
    "description": "FastAPI + Supabase + JWT auth + income/salary + expenses + reports.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "expense_id",
      "value": ""
    },
    {
      "key": "income_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Abhi\",\n  \"email\": \"abhi@example.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('access_token', json.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"abhi@example.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('access_token', json.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/profile",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "profile"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Abhi Smart\"\n}"
            }
          }
        },
        {
          "name": "Delete Account",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/account",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "account"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Income / Salary",
      "item": [
        {
          "name": "Add Salary",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 25000,\n  \"source\": \"Salary\",\n  \"note\": \"June salary\",\n  \"income_date\": \"2026-06-17\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/income/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "income",
                ""
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.income?.id) pm.collectionVariables.set('income_id', json.income.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Salary History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/income/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "income",
                ""
              ]
            }
          }
        },
        {
          "name": "Update Salary",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 30000,\n  \"note\": \"Updated salary entry\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/income/{{income_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "income",
                "{{income_id}}"
              ]
            }
          }
        },
        {
          "name": "Delete Salary",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/income/{{income_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "income",
                "{{income_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Expenses",
      "item": [
        {
          "name": "Add Expense",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 250,\n  \"category\": \"Food\",\n  \"payment_method\": \"UPI\",\n  \"description\": \"College canteen\",\n  \"expense_date\": \"2026-06-17\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/expenses/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "expenses",
                ""
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.expense?.id) pm.collectionVariables.set('expense_id', json.expense.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Expenses",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/expenses/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "expenses",
                ""
              ]
            }
          }
        },
        {
          "name": "Update Expense",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 300,\n  \"description\": \"Updated expense\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/expenses/{{expense_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "expenses",
                "{{expense_id}}"
              ]
            }
          }
        },
        {
          "name": "Delete Expense",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/expenses/{{expense_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "expenses",
                "{{expense_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Reports / Dashboard",
      "item": [
        {
          "name": "Overview",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/reports/overview",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "reports",
                "overview"
              ]
            }
          }
        },
        {
          "name": "Category Breakdown",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/reports/category-breakdown",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "reports",
                "category-breakdown"
              ]
            }
          }
        },
        {
          "name": "Monthly Trend",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/reports/monthly-trend",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "reports",
                "monthly-trend"
              ]
            }
          }
        },
        {
          "name": "Financial Health",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/reports/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "reports",
                "health"
              ]
            }
          }
        },
        {
          "name": "Recent Transactions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/reports/recent-transactions?limit=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "reports",
                "recent-transactions"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Current Month Category Breakdown",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/reports/category-breakdown?period=current_month",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "reports",
                "category-breakdown"
              ],
              "query": [
                {
                  "key": "period",
                  "value": "current_month"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "health"
          ]
        }
      }
    }
  ]
}